---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Subjects"
  description="Browse available QuizNiva subjects and topic collections."
  currentPath="/subjects"
>
  <section class="page-intro section">
    <p class="eyebrow">Subjects</p>
    <h1>Choose A Study Path</h1>
    <p>Start with Python programming or build your base with Computer Fundamentals. Each path includes short notes and MCQ practice.</p>
  </section>

  <section class="section section--tight">
    <div class="subject-list">
      <a class="subject-row" href="/python">
        <div>
          <h2>Python Beginner To Advanced</h2>
          <p>Short notes, code examples, MCQs, and answer explanations from core basics to advanced Python tools.</p>
        </div>
        <span>Open</span>
      </a>
      <a class="subject-row" href="/computer-fundamentals">
        <div>
          <h2>Computer Fundamentals</h2>
          <p>9 topic groups with lesson-level explanations and MCQ quizzes for hardware, CPU, RAM, storage, operating systems, internet, binary, networking, and cybersecurity.</p>
        </div>
        <span>Open</span>
      </a>
    </div>
  </section>
</BaseLayout>
