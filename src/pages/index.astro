---
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseProgress from "../components/CourseProgress.astro";
import HomePreview from "../components/HomePreview.astro";
import TopicCard from "../components/TopicCard.astro";
import topics from "../data/topics.json";
import {
  computerFundamentalsLessons,
  computerFundamentalsTopicGroups
} from "../data/computerFundamentalsCourse.js";

const sortedTopics = [...topics].sort((a, b) => a.order - b.order);
const pythonTopics = sortedTopics.filter((topic) => topic.subject === "Python");
const readyTopics = pythonTopics.filter((topic) => topic.status === "ready");
const beginnerTopics = readyTopics.filter((topic) => topic.difficulty === "Beginner");
const intermediateTopics = readyTopics.filter((topic) => topic.difficulty === "Intermediate");
const advancedTopics = readyTopics.filter((topic) => topic.difficulty === "Advanced");
const plannedTopics = pythonTopics.filter((topic) => topic.status !== "ready");
const beginnerStart = beginnerTopics[0];
const intermediateStart = intermediateTopics[0];
const advancedStart = advancedTopics[0];
const computerStart = computerFundamentalsLessons[0];
const computerQuestionCount = computerFundamentalsLessons.reduce((total, lesson) => total + lesson.questionCount, 0);
---

<BaseLayout
  title="QuizNiva"
  description="Free programming and computer fundamentals notes, MCQ quizzes, answer explanations, and progress-friendly practice."
>
  <section class="home-hero section">
    <div class="home-hero__copy">
      <p class="eyebrow">Focused study paths</p>
      <h1>QuizNiva</h1>
      <p>
        Build practical foundations with Python lessons and Computer Fundamentals notes, then lock in each topic with focused MCQs and answer explanations.
      </p>
      <div class="button-row">
        <a class="button button--primary" href="/python/variables" data-progress-continue-link>Start Python Variables</a>
        <a class="button button--ghost" href="/computer-fundamentals">Computer fundamentals</a>
      </div>
    </div>
    <HomePreview />
  </section>

  <CourseProgress topics={readyTopics} subjectName="Python" courseUrl="/python" />

  <section class="section section--tight" aria-labelledby="ready-title">
    <div class="section-heading">
      <p class="eyebrow">Study paths</p>
      <h2 id="ready-title">Choose Your Next Course</h2>
      <p>Start with foundations, jump into intermediate practice, sharpen advanced Python skills, or build the computer basics that support every technical path.</p>
    </div>

    <div class="course-level-grid">
      <article class="course-level-card">
        <p class="eyebrow">Beginner</p>
        <h3>Python Foundations</h3>
        <p>Variables, data types, input/output, conditions, loops, strings, lists, functions, dictionaries, and basic errors.</p>
        <div class="course-level-card__meta">
          <span>{beginnerTopics.length} lessons</span>
          <span>{beginnerTopics.length * 20} MCQs</span>
        </div>
        <div class="course-level-card__actions">
          <a class="button button--primary" href={beginnerStart?.contentUrl ?? "/python"}>Start beginner</a>
          <a class="button button--ghost" href="/python">View syllabus</a>
        </div>
      </article>

      <article class="course-level-card">
        <p class="eyebrow">Intermediate</p>
        <h3>Practical Python Patterns</h3>
        <p>Tuples, sets, comprehensions, files, exceptions, modules, OOP, inheritance, functional helpers, generators, and decorators.</p>
        <div class="course-level-card__meta">
          <span>{intermediateTopics.length} lessons</span>
          <span>{intermediateTopics.length * 20} MCQs</span>
        </div>
        <div class="course-level-card__actions">
          <a class="button button--primary" href={intermediateStart?.contentUrl ?? "/python"}>Start intermediate</a>
          <a class="button button--ghost" href="/python">View syllabus</a>
        </div>
      </article>

      <article class="course-level-card">
        <p class="eyebrow">Advanced</p>
        <h3>Professional Python Tools</h3>
        <p>Closures, context managers, regex, dataclasses, type hints, testing, async, concurrency, serialization, and debugging.</p>
        <div class="course-level-card__meta">
          <span>{advancedTopics.length} lessons</span>
          <span>{advancedTopics.length * 20} MCQs</span>
        </div>
        <div class="course-level-card__actions">
          <a class="button button--primary" href={advancedStart?.contentUrl ?? "/python"}>Start advanced</a>
          <a class="button button--ghost" href="/python">View syllabus</a>
        </div>
      </article>

      <article class="course-level-card">
        <p class="eyebrow">Computer Fundamentals</p>
        <h3>Core Computer Basics</h3>
        <p>9 topic groups covering hardware, CPU, RAM, storage, operating systems, internet, binary, networking, and cybersecurity.</p>
        <div class="course-level-card__meta">
          <span>{computerFundamentalsTopicGroups.length} topics</span>
          <span>{computerFundamentalsLessons.length} lessons</span>
          <span>{computerQuestionCount} MCQs</span>
        </div>
        <div class="course-level-card__actions">
          <a class="button button--primary" href={computerStart?.contentUrl ?? "/computer-fundamentals"}>Start fundamentals</a>
          <a class="button button--ghost" href="/computer-fundamentals">View syllabus</a>
        </div>
      </article>
    </div>
  </section>

  {plannedTopics.length > 0 && (
    <section class="section section--muted" aria-labelledby="roadmap-title">
      <div class="section-heading">
        <p class="eyebrow">Build queue</p>
        <h2 id="roadmap-title">Python Beginner Roadmap</h2>
        <p>These topics are planned next. We will add each only after its notes and quiz explanations are ready.</p>
      </div>

      <div class="topic-grid">
        {plannedTopics.map((topic) => <TopicCard topic={topic} />)}
      </div>
    </section>
  )}
</BaseLayout>
