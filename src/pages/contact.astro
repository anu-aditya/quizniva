---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Contact QuizNiva for corrections, suggestions, and content feedback."
  currentPath="/contact"
>
  <section class="page-intro section">
    <p class="eyebrow">Contact</p>
    <h1>Send Feedback</h1>
    <p>Use this page for corrections, topic suggestions, and general questions about QuizNiva.</p>
  </section>

  <section class="section contact-panel">
    <div>
      <h2>Email</h2>
      <p>
        <a class="text-link" href="mailto:contact@quizniva.in">contact@quizniva.in</a>
      </p>
    </div>

    <div>
      <h2>Content Corrections</h2>
      <p>
        When reporting an issue, include the page URL, the question or section title, and what should be corrected.
      </p>
    </div>
  </section>
</BaseLayout>
